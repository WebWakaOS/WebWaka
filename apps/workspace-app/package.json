    "react-dom": "^18.3.1",
    "react-hook-form": "^7.52.0",
    "react-router-dom": "^6.24.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.45.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/ui": "^1.6.0",
    "typescript": "^5.5.2",
    "vite": "6.4.2",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^1.6.0",
    "workbox-window": "^7.1.0"
