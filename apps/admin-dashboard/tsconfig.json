{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": false,
    "outDir": "./dist",
    "rootDir": "../..",
    "types": ["@cloudflare/workers-types"],
    "paths": {
      "@webwaka/ai": ["../../packages/ai-abstraction/src/index.ts"],
      "@webwaka/auth": ["../../packages/auth/src/index.ts"],
      "@webwaka/frontend": ["../../packages/frontend/src/index.ts"],
      "@webwaka/payments": ["../../packages/payments/src/index.ts"],
      "@webwaka/types": ["../../packages/types/src/index.ts"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
