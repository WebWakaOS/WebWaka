{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "description": "WebWaka API — Cloudflare Worker",
  "scripts": {
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "dev": "wrangler dev --env staging",
    "deploy:staging": "wrangler deploy --env staging",
    "deploy:production": "wrangler deploy --env production",
    "lint": "eslint src --ext .ts",
    "test": "echo \"No tests yet — skipping\" && exit 0"
  },
  "dependencies": {
    "@webwaka/auth": "workspace:*",
    "@webwaka/types": "workspace:*"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241230.0",
    "typescript": "^5.4.5",
    "wrangler": "^4.0.0"
  }
}
