{
  "extends": [
    "../../.eslintrc.base.json"
  ],
  "parserOptions": {
    "project": "./tsconfig.json"
  },
  "env": {
    "node": false,
    "es2022": true,
    "worker": true
  },
  "rules": {
    "@typescript-eslint/no-unused-vars": [
      "error",
      {
        "argsIgnorePattern": "^_",
        "varsIgnorePattern": "^_",
        "caughtErrorsIgnorePattern": "^_"
      }
    ]
  }
}
