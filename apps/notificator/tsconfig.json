{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": false,
    "outDir": "./dist",
    "rootDir": "../..",
    "types": ["@cloudflare/workers-types"],
    "paths": {
      "@webwaka/events": ["../../packages/events/src/index.ts"],
      "@webwaka/notifications": ["../../packages/notifications/src/index.ts"],
      "@webwaka/shared-config": ["../../packages/shared-config/src/index.ts"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
