{
  "name": "webwaka-os",
  "version": "0.0.0",
  "private": true,
  "description": "WebWaka OS monorepo — governance-driven platform for Africa",
  "scripts": {
    "dev": "node apps/platform-admin/server.js",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test",
    "lint": "pnpm -r run lint",
    "build": "pnpm -r run build",
    "clean": "pnpm -r run clean",
    "seed:wards": "tsx infra/db/seed/scripts/generate_wards_sql.ts"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "@typescript-eslint/eslint-plugin": "^7.9.0",
    "@typescript-eslint/parser": "^7.9.0",
    "eslint": "^8.57.0",
    "tsx": "^4.7.2",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "hono": "^4.12.12"
  },
  "pnpm": {
    "overrides": {
      "undici": ">=6.21.1"
    }
  }
}

