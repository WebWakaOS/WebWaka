{
  "name": "webwaka-os",
  "version": "1.0.0",
  "private": true,
  "description": "WebWaka OS monorepo — governance-driven platform for Africa",
  "scripts": {
    "dev": "node apps/platform-admin/server.js",
    "typecheck": "pnpm -r --parallel run typecheck",
    "test": "pnpm -r run test",
    "lint": "pnpm -r run lint",
    "build": "pnpm -r run build",
    "clean": "pnpm -r run clean",
    "seed:wards": "tsx infra/db/seed/scripts/generate_wards_sql.ts",
    "changeset:add": "changeset",
    "changeset:version": "changeset version && pnpm install --frozen-lockfile false",
    "changeset:publish": "changeset publish",
    "test:e2e": "playwright test",
    "test:e2e:api": "playwright test --project=api-e2e",
    "test:e2e:discovery": "playwright test --project=discovery-e2e",
    "test:e2e:report": "playwright show-report tests/e2e/reports",
    "test:visual": "playwright test --project=visual",
    "test:visual:update": "playwright test --project=visual --update-snapshots",
    "test:smoke": "tsx tests/smoke/cycle-01-smoke.ts",
    "test:cycle-01": "tsx tests/smoke/cycle-01-smoke.ts",
    "test:cycle-02": "playwright test --project=api-e2e tests/e2e/api/08-tenant-isolation.e2e.ts tests/e2e/api/09-jwt-csrf.e2e.ts tests/e2e/api/10-payment-integrity.e2e.ts tests/e2e/api/11-compliance-invariants.e2e.ts tests/e2e/api/12-l3-hitl.e2e.ts tests/e2e/api/13-mon04-limits.e2e.ts",
    "test:cycle-03": "playwright test --project=api-e2e tests/e2e/api/14-role-permission.e2e.ts",
    "test:cycle-04": "playwright test --project=api-e2e tests/e2e/api/15-compliance-full.e2e.ts",
    "test:cycle-05": "playwright test --project=api-e2e tests/e2e/api/16-bank-transfer-fsm.e2e.ts tests/e2e/api/17-wallet-lifecycle.e2e.ts",
    "test:cycle-06": "playwright test --project=api-e2e tests/e2e/api/18-b2b-marketplace.e2e.ts tests/e2e/api/19-negotiation.e2e.ts",
    "test:cycle-07": "playwright test --project=api-e2e tests/e2e/api/20-ussd.e2e.ts",
    "test:cycle-08": "playwright test --project=api-e2e tests/e2e/api/21-analytics-projections.e2e.ts",
    "test:cycle-09": "playwright test --project=visual tests/visual/",
    "test:critical-path": "pnpm test:cycle-01 && playwright test --project=api-e2e tests/e2e/api/08-tenant-isolation.e2e.ts tests/e2e/api/09-jwt-csrf.e2e.ts tests/e2e/api/10-payment-integrity.e2e.ts tests/e2e/api/11-compliance-invariants.e2e.ts tests/e2e/api/12-l3-hitl.e2e.ts",
    "test:compliance": "playwright test --project=api-e2e tests/e2e/api/11-compliance-invariants.e2e.ts tests/e2e/api/12-l3-hitl.e2e.ts tests/e2e/api/15-compliance-full.e2e.ts",
    "test:p9": "playwright test --project=api-e2e --grep 'P9|kobo|fractional'",
    "test:p0-blockers": "playwright test --project=api-e2e --grep 'TC-INV002|TC-INV003|TC-INV005|TC-AUTH003|TC-AUTH004|TC-CSRF001|TC-NE011|TC-HR001|TC-MON001|TC-MON003|TC-W003|TC-B009|TC-PROJ001|TC-US008|TC-US010'",
    "test:rls": "playwright test --project=api-e2e tests/e2e/api/25-cross-tenant-isolation.e2e.ts",
    "test:sprint4": "playwright test --project=api-e2e tests/e2e/api/22-partner-admin-session.e2e.ts tests/e2e/api/23-super-admin-actions.e2e.ts tests/e2e/api/24-ussd-full-journey.e2e.ts tests/e2e/api/25-cross-tenant-isolation.e2e.ts",
    "seed:phase-1": "./apps/api/node_modules/.bin/wrangler d1 execute webwaka-staging --env staging --config apps/api/wrangler.toml --remote --file=scripts/seed/phase-1-users.sql",
    "seed:phase-2": "./apps/api/node_modules/.bin/wrangler d1 execute webwaka-staging --env staging --config apps/api/wrangler.toml --remote --file=scripts/seed/phase-2-tenants.sql",
    "seed:phase-3": "./apps/api/node_modules/.bin/wrangler d1 execute webwaka-staging --env staging --config apps/api/wrangler.toml --remote --file=scripts/seed/phase-3-partners.sql",
    "seed:phase-4": "./apps/api/node_modules/.bin/wrangler d1 execute webwaka-staging --env staging --config apps/api/wrangler.toml --remote --file=scripts/seed/phase-4-financial.sql",
    "seed:phase-5": "./apps/api/node_modules/.bin/wrangler d1 execute webwaka-staging --env staging --config apps/api/wrangler.toml --remote --file=scripts/seed/phase-5-offerings.sql",
    "seed:phase-6": "./apps/api/node_modules/.bin/wrangler d1 execute webwaka-staging --env staging --config apps/api/wrangler.toml --remote --file=scripts/seed/phase-6-notifications.sql",
    "seed:phase-7": "./apps/api/node_modules/.bin/wrangler d1 execute webwaka-staging --env staging --config apps/api/wrangler.toml --remote --file=scripts/seed/phase-7-fx-rates.sql",
    "seed:phase-8": "./apps/api/node_modules/.bin/wrangler d1 execute webwaka-staging --env staging --config apps/api/wrangler.toml --remote --file=scripts/seed/phase-8-ussd-sessions.sql",
    "seed:all": "pnpm seed:phase-1 && pnpm seed:phase-2 && pnpm seed:phase-3 && pnpm seed:phase-4 && pnpm seed:phase-5 && pnpm seed:phase-6 && pnpm seed:phase-7 && pnpm seed:phase-8",
    "seed:reset-destructive": "./apps/api/node_modules/.bin/wrangler d1 execute webwaka-staging --env staging --config apps/api/wrangler.toml --remote --file=scripts/reset/reset-after-destructive.sql"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@playwright/test": "^1.49.0",
    "@types/node": "^20.19.39",
    "@typescript-eslint/eslint-plugin": "^7.9.0",
    "@typescript-eslint/parser": "^7.9.0",
    "eslint": "^8.57.0",
    "tsx": "^4.7.2",
    "typescript": "^5.4.5",
    "vitest": "^2.1.9"
  },
  "dependencies": {
    "@replit/connectors-sdk": "^0.4.0",
    "hono": "^4.12.14"
  },
  "pnpm": {
    "overrides": {
      "undici": ">=6.21.1",
      "esbuild": ">=0.25.0",
      "vite": ">=5.4.21",
      "serialize-javascript": ">=7.0.3",
      "postcss": ">=8.5.10"
    },
    "patchedDependencies": {
      "vite-node@2.1.9": "patches/vite-node@2.1.9.patch"
    }
  }
}