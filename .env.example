# WebWaka OS — Environment Variables Example
# Copy this to .env.local for local development
# NEVER commit .env.local or any file with real values

# Cloudflare
CLOUDFLARE_ACCOUNT_ID=your_account_id_here
CLOUDFLARE_API_TOKEN=your_api_token_here

# JWT
JWT_SECRET=your_local_dev_secret_here_min_32_chars

# Database (for local wrangler dev)
# D1 database IDs are in wrangler.toml — not needed in .env for local dev

# AI Providers (optional — BYOK)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=
