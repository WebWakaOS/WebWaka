{
  "name": "@webwaka/provider-registry",
  "version": "0.1.0",
  "private": true,
  "description": "[Infra] Platform-managed provider registry with encrypted credentials, hierarchical resolution, and audit logging",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "source": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250214.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.9"
  }
}
