{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022"],
    "rootDir": "src",
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@webwaka/types": ["../types/src/index.ts"],
      "@webwaka/entitlements": ["../entitlements/src/index.ts"],
      "@webwaka/payments": ["../payments/src/index.ts"],
      "@webwaka/identity": ["../identity/src/index.ts"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist", "src/**/*.test.ts"]
}
