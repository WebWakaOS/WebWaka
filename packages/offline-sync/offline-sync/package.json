{
  "name": "@webwaka/offline-sync",
  "version": "0.1.0",
  "private": true,
  "description": "[Infra] PWA offline sync runtime (Dexie.js + SyncEngine + Service Worker) for WebWaka OS.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "source": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@webwaka/types": "workspace:*",
    "dexie": "^3.2.7"
  },
  "devDependencies": {
    "fake-indexeddb": "^6.0.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0",
    "jsdom": "^24.0.0",
    "@types/jsdom": "^21.0.0"
  }
}
