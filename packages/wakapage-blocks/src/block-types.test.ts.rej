@@ -252,16 +252,16 @@
   it('retains specific mutual_aid_wall fields on parse', () => {
     const config: MutualAidWallBlockConfig = {
       heading: 'Mutual Aid Wall',
-      showDisbursements: true,
-      allowAnonRequests: false,
+      showOpenRequests: true,
+      showRequestAmount: false,
     };
     const json = JSON.stringify(config);
     const parsed = parseBlockConfig('mutual_aid_wall', json);
     expect(parsed).not.toBeNull();
     if (parsed && parsed.blockType === 'mutual_aid_wall') {
-      expect(parsed.showDisbursements).toBe(true);
-      expect(parsed.allowAnonRequests).toBe(false);
+      expect(parsed.showOpenRequests).toBe(true);
+      expect(parsed.showRequestAmount).toBe(false);
     }
   });
 });

