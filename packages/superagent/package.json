{
  "name": "@webwaka/superagent",
  "version": "0.1.0",
  "private": true,
  "description": "[AI] SuperAgent service — key management, WakaCU wallet, credit burn, usage metering. Cross-cutting AI layer (NOT a 4th pillar).",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "source": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@webwaka/ai": "workspace:*",
    "@webwaka/ai-adapters": "workspace:*",
    "@webwaka/auth": "workspace:*",
    "@webwaka/entitlements": "workspace:*",
    "@webwaka/types": "workspace:*"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241205.0",
    "@vitest/coverage-v8": "^2.1.9",
    "typescript": "^5.4.5",
    "vitest": "^2.1.9"
  }
}
